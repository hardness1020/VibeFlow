{
  "description": "VibeFlow workflow enforcement hooks",
  "hooks": {
    "_disabled_UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project ${CLAUDE_PLUGIN_ROOT}/hooks/workflow-state-inject.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "uv run --no-project ${CLAUDE_PLUGIN_ROOT}/hooks/workitem-branch-guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "uv run --no-project ${CLAUDE_PLUGIN_ROOT}/hooks/checkpoint-gate.py",
            "timeout": 15
          }
        ]
      }
    ],
    "_disabled_PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project ${CLAUDE_PLUGIN_ROOT}/hooks/git-push-guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "_disabled_Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project ${CLAUDE_PLUGIN_ROOT}/hooks/auto-validate.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "uv run --no-project ${CLAUDE_PLUGIN_ROOT}/hooks/doc-path-tracker.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "uv run --no-project ${CLAUDE_PLUGIN_ROOT}/hooks/stage-transition-update.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
